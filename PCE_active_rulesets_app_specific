import json
import requests
from requests.auth import HTTPBasicAuth
import urllib3

from illumio.workloads import output_file

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

ORG_ID = "yyyy"
RULESET_ID = "16044073672541582"   # <-- from UI URL

headers = {
    "Accept": "application/json",
    "Content-Type": "application/json"
}

AUTH = HTTPBasicAuth(
    "api_xxxxx",
    "yyyyyyy"
)

url = (
    f"https://uk-yyyy.illum.io/api/v2/orgs/{ORG_ID}"
    f"/sec_policy/draft/rule_sets/{RULESET_ID}"
)

response = requests.get(url, auth=AUTH, verify=False, headers=headers)
response.raise_for_status()

ruleset = response.json()

print("Rule set name:", ruleset.get("name"))
print(json.dumps(ruleset, indent=2))

print(response.status_code)
pretty_response = json.dumps(response.json(), indent=4)
print(pretty_response)

output_file = open('pcheck_output.txt', 'w')
output_file.write(pretty_response)
